{
  "name": "loop-browser",
  "version": "0.0.1",
  "private": true,
  "main": "main.js",
  "description": "Loop Browser — command the web from your CLI, and watch it happen",
  "bin": {
    "loop": "cli.mjs"
  },
  "scripts": {
    "prestart": "node scripts/rebrand-electron.mjs",
    "start": "electron .",
    "cli": "node cli.mjs",
    "install-skill": "node scripts/install-skill.mjs",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:win:signed": "electron-builder --win --config electron-builder.signing.js",
    "site": "node scripts/dev-server.mjs"
  },
  "build": {
    "appId": "com.mytablon.loopbrowser",
    "productName": "Loop Browser",
    "directories": {
      "output": "build/dist"
    },
    "asar": false,
    "files": [
      "main.js",
      "cli.mjs",
      "lib.mjs",
      "ui/**/*",
      "assets/**/*",
      "bin/**/*",
      "recipes/**/*",
      "!recipes/local/**",
      "package.json",
      "!node_modules/playwright/**"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": "universal"
        }
      ],
      "icon": "assets/loop.icns",
      "category": "public.app-category.productivity",
      "artifactName": "Loop-Browser-mac.${ext}"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/loop-dock-icon.png",
      "artifactName": "Loop-Browser-win.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Loop Browser"
    }
  },
  "dependencies": {
    "playwright-core": "^1.61.0"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  }
}
