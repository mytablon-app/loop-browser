{
  "name": "loop-browser",
  "version": "0.0.8",
  "main": "main.js",
  "description": "Loop Browser — command the web from your CLI, and watch it happen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mytablon-app/loop-browser.git"
  },
  "homepage": "https://loop-browser.vercel.app",
  "keywords": [
    "browser",
    "automation",
    "cli",
    "electron",
    "playwright",
    "claude-code",
    "web-automation",
    "recipes"
  ],
  "bin": {
    "loop": "cli.mjs",
    "loop-browser": "bin/launch.mjs"
  },
  "files": [
    "main.js",
    "cli.mjs",
    "lib.mjs",
    "wa.mjs",
    "porter.mjs",
    "servicelog.mjs",
    "stats.mjs",
    "ui/",
    "assets/",
    "bin/",
    "recipes/*.json",
    "site-memories/*.md",
    "skill/",
    "README.md",
    "PLAYBOOK.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "node -e \"try{require('child_process').execSync('git config core.hooksPath .githooks')}catch(e){}\"",
    "prestart": "node scripts/rebrand-electron.mjs",
    "start": "electron .",
    "cli": "node cli.mjs",
    "test": "node tests/run.mjs",
    "check:bundle": "node scripts/check-bundled-imports.mjs",
    "prepublishOnly": "node scripts/check-no-secrets.mjs && node scripts/check-bundled-imports.mjs",
    "install-skill": "node scripts/install-skill.mjs",
    "pack": "npm run check:bundle && electron-builder --dir",
    "dist": "npm run check:bundle && electron-builder --mac",
    "dist:win": "npm run check:bundle && electron-builder --win",
    "dist:win:signed": "npm run check:bundle && electron-builder --win --config electron-builder.signing.js",
    "site": "node scripts/dev-server.mjs"
  },
  "build": {
    "appId": "com.mytablon.loopbrowser",
    "productName": "Loop Browser",
    "directories": {
      "output": "build/dist"
    },
    "asar": false,
    "files": [
      "main.js",
      "cli.mjs",
      "lib.mjs",
      "wa.mjs",
      "porter.mjs",
      "servicelog.mjs",
      "stats.mjs",
      "ui/**/*",
      "assets/**/*",
      "bin/**/*",
      "recipes/**/*",
      "!recipes/local/**",
      "skill/**/*",
      "PLAYBOOK.md",
      "site-memories/*.md",
      "!site-memories/local/**",
      "package.json",
      "!node_modules/playwright/**"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": "universal"
        }
      ],
      "icon": "assets/loop.icns",
      "category": "public.app-category.productivity",
      "artifactName": "Loop-Browser-mac.${ext}"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/loop-dock-icon.png",
      "artifactName": "Loop-Browser-win.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Loop Browser"
    }
  },
  "dependencies": {
    "playwright-core": "^1.61.0"
  },
  "peerDependencies": {
    "electron": "^33.4.11"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  }
}
