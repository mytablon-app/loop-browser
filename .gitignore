# --- dependencies ---
node_modules/

# --- 🔴 PRIVACY-CRITICAL: never commit these ---
# Persistent login profile = live cookies/sessions for LinkedIn, Eventbrite, etc.
# Committing this publishes your logins. Stays on your machine, always.
.loop-profile/
user-data/
*.profile/

# Failure screenshots can show logged-in/private pages (DMs, personal data).
runs/

# The DISH = cooked output (e.g. scraped member CSVs). Personal data — each user
# cooks their OWN from their OWN session. Never shared. The recipe travels, not the meal.
dishes/
*-members.csv

# Distributable binaries served by the landing site — big, built per-release.
# Host via GitHub Release (preferred) or drop here locally; never commit.
site/downloads/
*.dmg
*.exe

# Your PRIVATE recipes (may hardcode company IDs / personal text).
# Ship templates in recipes/, keep personal ones in recipes/local/ (folder kept, contents ignored).
recipes/local/*
!recipes/local/.gitkeep
*.local.json

# Secrets (e.g. a cloud LLM key for the chef, if ever used).
.env
.env.*

# --- build artifacts ---
build/

# --- Chrome-for-Testing path, set aside (kept on disk, not committed) ---
serve.mjs

# --- OS junk ---
.DS_Store

# Local Claude Code runtime state (locks, etc.) — not source
.claude/

# Site MODEL ships (site-memories/*.md = how a public site works = shareable method).
# Our specifics (companyId, paths, account state, real names) stay PRIVATE in
# site-memories/local/ (and recipes/local). Scrub packs before they ship.
site-memories/local/*
!site-memories/local/.gitkeep
